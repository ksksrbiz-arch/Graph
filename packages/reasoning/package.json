{
  "name": "@pkg/reasoning",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight ML reasoning primitives for the knowledge graph: deterministic text embeddings, cosine similarity, structural link prediction (common-neighbours / Jaccard / Adamic-Adar), and weighted reasoning-path search. Pure TypeScript — no runtime model dependencies.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "pretype-check": "pnpm --filter @pkg/shared run build",
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "pretest": "pnpm --filter @pkg/shared run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@pkg/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
