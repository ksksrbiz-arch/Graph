# Copy to .env and fill in. Validated at API startup via zod (Rule 5).

# ── Postgres ──────────────────────────────────────────────────────
POSTGRES_URL=postgresql://pkg:pkg@localhost:5432/pkg

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Meilisearch ──────────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key-change-me

# ── API ───────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-32+-bytes-of-random
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ── Brain runtime ─────────────────────────────────────────────────
# Comma-separated user ids to auto-start on API boot.
BRAIN_AUTO_START_USER_IDS=
# Whether auto-started brains should also enter the dream cycle.
BRAIN_AUTO_START_DREAM=false
BRAIN_DEFAULT_AWAKE_MS=300000
BRAIN_DEFAULT_DREAM_MS=30000
# Redis-backed ownership lock TTL for singleton brain execution.
BRAIN_LOCK_TTL_SECONDS=120

# ── Public ingest (demo / Cloudflare website) ─────────────────────
# Comma-separated user ids that may write through /api/v1/public/ingest/*.
# Empty string disables public ingest entirely.
PUBLIC_INGEST_USER_IDS=
PUBLIC_INGEST_MAX_BYTES=262144

# Master KEK (Key Encryption Key) for wrapping per-user DEKs.
# 32 random bytes, base64-encoded. See ADR-006.
# Generate with: openssl rand -base64 32
KEK_BASE64=

# ── GitHub ingester (scripts/ingest-github.mjs) ──────────────────
# Personal access token — required for GitHub ingestion.
GITHUB_TOKEN=
# GitHub username/org to fetch (defaults to the token's authenticated user).
GITHUB_LOGIN=
# Max repos to fetch (default: 50).
GITHUB_REPOS_LIMIT=50
# Max issues+PRs per repo (default: 30).
GITHUB_ITEMS_LIMIT=30
# When set, nodes/edges are also pushed to the live Worker after local save.
# Example: https://graph.skdev-371.workers.dev
GRAPH_API_URL=
# userId passed to the Worker ingest endpoint. Leave blank to default to
# the resolved GitHub login (recommended — keeps non-local data scoped to
# your real account). Set to "local" for the shared demo slot.
GRAPH_USER_ID=

# ── Connector feature flags (Rule 4) ─────────────────────────────
FEATURE_CONNECTOR_GITHUB=false
FEATURE_CONNECTOR_GMAIL=false
FEATURE_CONNECTOR_OUTLOOK_MAIL=false
FEATURE_CONNECTOR_NOTION=false
FEATURE_CONNECTOR_OBSIDIAN=false
FEATURE_CONNECTOR_GITLAB=false
FEATURE_CONNECTOR_GOOGLE_CALENDAR=false
FEATURE_CONNECTOR_OUTLOOK_CALENDAR=false
FEATURE_CONNECTOR_TODOIST=false
FEATURE_CONNECTOR_LINEAR=false
FEATURE_CONNECTOR_BOOKMARKS=false

# ── OAuth provider credentials (filled per-deploy) ───────────────
# All optional — leave blank to disable that provider's connector.
# Each provider's setup is documented in docs/connectors/.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
TODOIST_OAUTH_CLIENT_ID=
TODOIST_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=

# ── Web ───────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
